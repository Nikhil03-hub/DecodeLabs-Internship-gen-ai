# DecodeLabs GenAI — Week 1: AI Chatbot with Memory
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# LLM Provider: "gemini" (default) | future: "openai" | "anthropic"
LLM_PROVIDER=gemini

# Google Gemini API key — get yours free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default model ID
# See current models at https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Flask debug mode (never true in production)
# FLASK_DEBUG=false

# Optional: Flask secret key (auto-generated if not set)
# FLASK_SECRET_KEY=change_me_in_production
