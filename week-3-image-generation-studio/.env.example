# Week 3 — AI Image Generation Studio
# Copy this to .env and fill in your values. Never commit .env to git.

# Hugging Face token — free tier, get at https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Model to use (free serverless)
HF_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0

# Flask secret key — any random string
FLASK_SECRET_KEY=change-me-in-production
